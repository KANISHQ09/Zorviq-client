# Zorviq Frontend Environment Variables

# API Base URL configuration.
# To use local backend, uncomment the line below and comment the production line:
NEXT_PUBLIC_API_URL=http://localhost:3000

# Production/Remote Backend URL:
# NEXT_PUBLIC_API_URL=https://zorviq.duckdns.org

# Backward compatibility / Server-side environment variable
# API_BASE_URL=https://zorviq.duckdns.org
API_BASE_URL=http://localhost:3000